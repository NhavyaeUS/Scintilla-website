# Microsoft Azure AD App Registration
MS_TENANT_ID=your-azure-tenant-id
MS_CLIENT_ID=your-azure-client-id
MS_CLIENT_SECRET=your-azure-client-secret

# Microsoft OneDrive
MS_DRIVE_USER_ID=user@yourtenant.onmicrosoft.com
MS_ONEDRIVE_ROOT_FOLDER=ScintillaSubmissions

# Microsoft Excel Workbook (relative path inside OneDrive)
MS_EXCEL_WORKBOOK_PATH=ScintillaSubmissions/Submissions.xlsx
MS_EXCEL_TABLE_NAME=Submissions

# Security
STATUS_BEARER_TOKEN=your_super_secret_token
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5500

# Server
NODE_ENV=development
PORT=3000
